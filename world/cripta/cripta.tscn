[sub_resource type="GDScript" id="GDScript_3umrf"]
script/source = "extends Area2D

# Referência ao nó do ícone no jogador
var player_icon: Node2D = null

func _on_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"player\"):
		# Pega o nó do ícone dentro do jogador
		player_icon = body.get_node(\"Icone_interacao\")
		player_icon.visible = true

func _on_body_exited(body: Node2D) -> void:
	if body.is_in_group(\"player\"):
		if player_icon:
			player_icon.visible = false
			player_icon = null
"

